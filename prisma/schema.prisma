generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

enum BoardVisibility {
  Public
  Private
  Unlisted

  @@schema("public")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  links         Link[]
  boards        Board[]

  @@map("users")
  @@schema("public")
}

model Link {
  id          String      @id @default(uuid()) @db.Uuid
  slug        String      @unique
  targetUrl   String      @map("target_url")
  title       String?
  description String?
  tags        String[]    @default([])
  expiresAt   DateTime?   @map("expires_at")
  userId      String      @map("user_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardLinks  BoardLink[]

  @@index([slug], map: "idx_links_slug")
  @@index([userId], map: "idx_links_user_id")
  @@map("links")
  @@schema("public")
}

model Board {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  slug        String          @unique
  description String?
  visibility  BoardVisibility @default(Private)
  userId      String          @map("user_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardLinks  BoardLink[]

  @@index([userId])
  @@map("boards")
  @@schema("public")
}

model BoardLink {
  id       String   @id @default(uuid()) @db.Uuid
  boardId  String   @map("board_id") @db.Uuid
  linkId   String   @map("link_id") @db.Uuid
  position Int
  addedAt  DateTime @default(now()) @map("added_at")
  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  link     Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@unique([boardId, linkId])
  @@index([boardId, position])
  @@map("board_links")
  @@schema("public")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refreshToken      String?  @map("refresh_token") @db.Text
  accessToken       String?  @map("access_token") @db.Text
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type")
  scope             String?
  idToken           String?  @map("id_token") @db.Text
  sessionState      String?  @map("session_state")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}
